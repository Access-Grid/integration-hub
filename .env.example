# Required. Generate once and never lose it — re-running the wizard requires
# a fresh DB if this key changes.
#
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AG_SYNC_ENCRYPTION_KEY=

# Optional. Override the default bind address / port.
AG_SYNC_HOST=0.0.0.0
AG_SYNC_PORT=5355

# Optional. Override the default DB path.
# AG_SYNC_DB_PATH=C:\ProgramData\AGSyncTool\app.db
